# Copy this file to keystore.properties and fill in your values.
# keystore.properties is gitignored — never commit the real file.
#
# To generate a keystore (run once, store the file safely outside the repo):
#   keytool -genkey -v -keystore keystore.jks -alias kartoshka \
#           -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=keystore.jks
storePassword=
keyAlias=kartoshka
keyPassword=
