# Copy this file content into local.properties and fill in your values.
# local.properties is gitignored — never commit it.

# Android SDK path (set automatically by Android Studio)
# sdk.dir=/path/to/sdk

# AppMetrica crash reporting — get key at appmetrica.yandex.ru
APPMETRICA_API_KEY=

# Keystore signing (for release builds) — see keystore.properties.example instead
