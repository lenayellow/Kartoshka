#!/usr/bin/env bash
# Blocks commits that introduce the old project name «Картошк» into
# user-visible code files (.kt / .go / .xml). Only NEW lines are checked,
# so existing legitimate occurrences (e.g. the vegetable in ItemCategory.kt
# or the comment in 001_init.yql) do not trigger the hook.
#
# To bypass once: git commit --no-verify

PATTERN='Картошк'
NEW_NAME='Супер Списки'

diff_output=$(git diff --cached --unified=0 -- '*.kt' '*.go' '*.xml')
[[ -z "$diff_output" ]] && exit 0

violations=0
current_file=""
current_line=0

while IFS= read -r line; do
    if [[ "$line" =~ ^\+\+\+\ b/(.+)$ ]]; then
        current_file="${BASH_REMATCH[1]}"
        continue
    fi
    if [[ "$line" =~ ^@@\ .*\+([0-9]+) ]]; then
        current_line="${BASH_REMATCH[1]}"
        continue
    fi
    # Skip the +++ header (matched above) and only count single '+' lines.
    if [[ "$line" == +* && "$line" != +++* ]]; then
        content="${line:1}"
        if [[ "$content" == *"$PATTERN"* ]]; then
            if [[ $violations -eq 0 ]]; then
                echo "" >&2
                echo "✗ pre-commit: «$PATTERN» found in newly added lines:" >&2
                echo "" >&2
            fi
            echo "  $current_file:$current_line" >&2
            echo "      $content" >&2
            violations=$((violations + 1))
        fi
        current_line=$((current_line + 1))
    fi
done <<< "$diff_output"

if [[ $violations -gt 0 ]]; then
    echo "" >&2
    echo "  Rename to «$NEW_NAME» before committing." >&2
    echo "  To bypass this check once: git commit --no-verify" >&2
    echo "" >&2
    exit 1
fi

exit 0
