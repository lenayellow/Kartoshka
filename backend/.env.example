# YDB Serverless
YDB_ENDPOINT=grpcs://ydb.serverless.yandexcloud.net:2135
YDB_DATABASE=/ru-central1/b1g.../etn...
YDB_SA_KEY_FILE=./sa-key.json

# Yandex ID OAuth
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=kartoshka://auth/yandex/callback

# JWT
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Yandex Object Storage
S3_ENDPOINT=https://storage.yandexcloud.net
S3_BUCKET=kartoshka-media
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Firebase Cloud Messaging
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=./fcm-sa.json

# RuStore Push
RUSTORE_PROJECT_ID=
RUSTORE_SERVICE_TOKEN=

# Email (SMTP Яндекс)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.ru
SMTP_PASS=

PORT=8080
ENV=production

# URL бэкенда (для ссылок в письмах)
APP_BASE_URL=https://api.kartoshka.app
